# Whale Social Media - Environment Configuration
# Copy this file to .env and fill in your values

# Database Configuration
DB_PASSWORD=your_secure_database_password_here
DATABASE_URL=postgresql://whale_user:your_secure_database_password_here@localhost:5432/whale

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security Keys (Generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_64_character_secret_key_here_change_this_in_production
WHALE_ENCRYPTION_KEY=your_32_byte_base64_encoded_encryption_key_here

# Application Settings
FLASK_ENV=production
DEBUG=false
TESTING=false

# File Upload
MAX_CONTENT_LENGTH=5242880
UPLOAD_FOLDER=static/uploads

# Session Configuration
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
PERMANENT_SESSION_LIFETIME=7200

# Rate Limiting
RATE_LIMIT_DEFAULT=200 per hour
RATE_LIMIT_LOGIN=5 per 15 minutes
RATE_LIMIT_SIGNUP=3 per hour

# Monitoring
GRAFANA_PASSWORD=your_grafana_password_here
PROMETHEUS_RETENTION_DAYS=30

# Kubernetes (if using K8s)
K8S_NAMESPACE=whale
K8S_CLUSTER_NAME=whale-cluster

# CDN (if using Cloudflare)
CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE_ID=your_cloudflare_zone_id

# Email (for notifications - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Optional: External Services
SENTRY_DSN=your_sentry_dsn_for_error_tracking
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key