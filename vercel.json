{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "DEBUG": "false",
    "TESTING": "false",
    "SECRET_KEY": "change-this-to-a-secure-random-key-in-vercel-dashboard",
    "WHALE_ENCRYPTION_KEY": "change-this-to-a-secure-random-key-in-vercel-dashboard"
  },
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
